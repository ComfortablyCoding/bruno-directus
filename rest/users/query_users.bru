meta {
  name: query_users
  type: http
  seq: 1
}

get {
  url: {{base_url}}/users
  body: none
  auth: inherit
}

params:query {
  ~fields: id,title,date_created
  ~filter: {"status":{"_eq":"published"}}
  ~sort: -date_created
  ~limit: 10
  ~offset: 0
  ~search: keyword
  ~meta: total_count,filter_count
}

docs {
  Retrieve a list of users with optional filtering, sorting, and pagination.
  https://directus.io/docs/api/users
}
