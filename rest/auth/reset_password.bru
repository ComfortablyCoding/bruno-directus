meta {
  name: reset_password
  type: http
  seq: 5
}

post {
  url: {{base_url}}/auth/password/reset
  body: json
  auth: inherit
}

body:json {
  {
    "token": "reset-token",
    "password": "new-password"
  }
}

docs {
  Reset a user's password using a valid reset token.
  https://directus.io/docs/api/authentication
}
