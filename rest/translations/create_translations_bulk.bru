meta {
  name: create_translations_bulk
  type: http
  seq: 4
}

post {
  url: {{base_url}}/translations
  body: json
  auth: inherit
}

body:json {
  [
    {"key": "welcome_message", "language": "en-US", "value": "Welcome to our app"},
    {"key": "welcome_message", "language": "fr-FR", "value": "Bienvenue dans notre application"}
  ]
}

docs {
  Create multiple custom translation strings in a single request.
  https://directus.io/docs/api/translations
}
