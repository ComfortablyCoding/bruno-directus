meta {
  name: query_activity
  type: http
  seq: 1
}

get {
  url: {{base_url}}/activity
  body: none
  auth: inherit
}

params:query {
  ~fields: id,action,user,timestamp,collection,item
  ~filter: {"status":{"_eq":"published"}}
  ~sort: -timestamp
  ~limit: 10
  ~offset: 0
  ~search: keyword
  ~meta: total_count,filter_count
}

docs {
  Retrieve a list of all activity records in the system.
  https://directus.io/docs/api/activity
}
