meta {
  name: query_revisions
  type: http
  seq: 1
}

get {
  url: {{base_url}}/revisions
  body: none
  auth: inherit
}

params:query {
  ~fields: id,collection,item,data,activity
  ~filter: {"status":{"_eq":"published"}}
  ~sort: -date_created
  ~limit: 10
  ~offset: 0
  ~search: keyword
  ~meta: total_count,filter_count
}

docs {
  Retrieve a list of all revisions in the system.
  https://directus.io/docs/api/revisions
}
