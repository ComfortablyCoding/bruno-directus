meta {
  name: query_roles
  type: http
  seq: 1
}

get {
  url: {{base_url}}/roles
  body: none
  auth: inherit
}

params:query {
  ~fields: id,name,icon
  ~filter: {"status":{"_eq":"published"}}
  ~sort: -date_created
  ~limit: 10
  ~offset: 0
  ~search: keyword
  ~meta: total_count,filter_count
}

docs {
  Retrieve a list of all roles in the system.
  https://directus.io/docs/api/roles
}
