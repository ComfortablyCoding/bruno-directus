meta {
  name: query_role_by_id
  type: http
  seq: 2
}

get {
  url: {{base_url}}/roles/:id
  body: none
  auth: inherit
}

params:path {
  id: role-id
}

params:query {
  ~fields: id,title,date_created
  ~filter: {"status":{"_eq":"published"}}
  ~sort: -date_created
  ~limit: 10
  ~offset: 0
  ~search: keyword
  ~meta: total_count,filter_count
}

docs {
  Retrieve a single role by its primary key.
  https://directus.io/docs/api/roles
}
