meta {
  name: query_presets
  type: http
  seq: 1
}

get {
  url: {{base_url}}/presets
  body: none
  auth: inherit
}

params:query {
  ~fields: id,collection,layout
  ~filter: {"status":{"_eq":"published"}}
  ~sort: -date_created
  ~limit: 10
  ~offset: 0
  ~search: keyword
  ~meta: total_count,filter_count
}

docs {
  Retrieve a list of all presets in the system.
  https://directus.io/docs/api/presets
}
