post {
  url: {{base_url}}/shares/auth
  body: json
  auth: inherit
}

body:json {
  {
    "share": "share-id",
    "password": "optional-password"
  }
}

docs {
  Authenticate against a password-protected share to obtain access.
  https://directus.io/docs/api/shares
}
