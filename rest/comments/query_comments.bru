meta {
  name: query_comments
  type: http
  seq: 1
}

get {
  url: {{base_url}}/comments
  body: none
  auth: inherit
}

params:query {
  ~fields: id,collection,item,comment,date_created
  ~filter: {"status":{"_eq":"published"}}
  ~sort: -date_created
  ~limit: 10
  ~offset: 0
  ~search: keyword
  ~meta: total_count,filter_count
}

docs {
  Retrieve a list of all comments in the system.
  https://directus.io/docs/api/comments
}
