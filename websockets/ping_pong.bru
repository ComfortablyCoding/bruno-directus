meta {
  name: ping_pong
  type: ws
  seq: 4
}

ws {
  url: {{base_url}}/websocket
  body: ws
  auth: none
}

body:ws {
  name: pong
  type: json
  content: '''
    {
      "type": "pong"
    }
  '''
}

docs {
  Respond to server ping messages to keep the connection alive.
  Server sends ping every 30 seconds.
  
  https://directus.io/docs/guides/realtime/subscriptions
}
