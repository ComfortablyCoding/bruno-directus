meta {
  name: auth_handshake
  type: ws
  seq: 1
}

ws {
  url: {{base_url}}/websocket
  body: ws
  auth: none
}

body:ws {
  name: authenticate
  type: json
  content: '''
    {
      "type": "auth",
      "access_token": "{{access_token}}"
    }
  '''
}

docs {
  Authenticate a WebSocket connection using a static access token.
  Must be sent as the first message after connecting.
  
  https://directus.io/docs/guides/realtime/subscriptions
}
