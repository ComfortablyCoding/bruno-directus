meta {
  name: query_item_by_id
  type: http
  seq: 2
}

post {
  url: {{base_url}}/graphql
  body: graphql
  auth: inherit
}

body:graphql {
  query ArticleById($id: ID!) {
    articles_by_id(id: $id) {
      id
      title
      status
      body
      date_created
    }
  }
}

body:graphql:vars {
  {
    "id": "1"
  }
}

docs {
  Query a single item by its primary key via GraphQL.
  https://directus.io/docs/api/graphql
}
