meta {
  name: query_items
  type: http
  seq: 1
}

post {
  url: {{base_url}}/graphql
  body: graphql
  auth: inherit
}

body:graphql {
  query {
    articles(limit: 10, sort: ["-date_created"]) {
      id
      title
      status
      date_created
    }
  }
}

docs {
  Query a list of items from a user collection via GraphQL.
  https://directus.io/docs/api/graphql
}
