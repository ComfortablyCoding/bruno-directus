meta {
  name: create_items_bulk
  type: http
  seq: 2
}

post {
  url: {{base_url}}/graphql
  body: graphql
  auth: inherit
}

body:graphql {
  mutation {
    create_articles_items(data: [{ title: "Article 1" }, { title: "Article 2" }]) {
      id
      title
    }
  }
}

docs {
  Create multiple items in a collection in a single GraphQL mutation.
  https://directus.io/docs/api/graphql
}
