meta {
  name: update_item
  type: graphql
  seq: 3
}

post {
  url: {{base_url}}/graphql
  body: graphql
  auth: inherit
}

body:graphql {
  mutation UpdateArticle($id: ID!) {
    update_articles_item(id: $id, data: { title: "Updated Article" }) {
      id
      title
    }
  }
}

body:graphql:vars {
  {
    "id": "1"
  }
}

docs {
  Update a single item in a collection via GraphQL mutation.
  https://directus.io/docs/api/graphql
}
