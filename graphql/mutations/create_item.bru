meta {
  name: create_item
  type: graphql
  seq: 1
}

post {
  url: {{base_url}}/graphql
  body: graphql
  auth: inherit
}

body:graphql {
  mutation {
    create_articles_item(data: { title: "New Article", status: "draft" }) {
      id
      title
    }
  }
}

docs {
  Create a single item in a collection via GraphQL mutation.
  https://directus.io/docs/api/graphql
}
