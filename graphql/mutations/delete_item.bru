meta {
  name: delete_item
  type: graphql
  seq: 5
}

post {
  url: {{base_url}}/graphql
  body: graphql
  auth: inherit
}

body:graphql {
  mutation DeleteArticle($id: ID!) {
    delete_articles_item(id: $id) {
      id
    }
  }
}

body:graphql:vars {
  {
    "id": "1"
  }
}

docs {
  Delete a single item from a collection via GraphQL mutation.
  https://directus.io/docs/api/graphql
}
